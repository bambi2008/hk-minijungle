VISION_PROVIDER=qwen
DASHSCOPE_API_KEY=
QWEN_VISION_MODEL=qwen-vl-plus
VISION_REQUEST_TIMEOUT_MS=45000

# Optional auxiliary reasoning model. Qwen remains the vision provider; MiniMax reviews
# diagnosis evidence, pathology matches, missing info, and one next action.
AUX_LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.chat/v1
AUX_LLM_REQUEST_TIMEOUT_MS=30000

# Optional legacy fallback only. Prefer Qwen-VL / a domestic provider for FiveCrop.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
